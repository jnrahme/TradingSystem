{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://newtradingsystem.local/schemas/order-intent.schema.json",
  "title": "OrderIntent",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "intent_id",
    "strategy_id",
    "account_scope",
    "instrument",
    "side",
    "order_type",
    "time_in_force",
    "quantity",
    "submitted_at",
    "reason"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "intent_id": {
      "type": "string"
    },
    "strategy_id": {
      "type": "string"
    },
    "account_scope": {
      "type": "string"
    },
    "instrument": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "symbol",
        "asset_class"
      ],
      "properties": {
        "symbol": {
          "type": "string"
        },
        "asset_class": {
          "type": "string",
          "enum": [
            "equities",
            "options",
            "futures",
            "crypto"
          ]
        },
        "venue_hint": {
          "type": "string"
        }
      }
    },
    "side": {
      "type": "string",
      "enum": [
        "buy",
        "sell",
        "sell_short",
        "buy_to_cover"
      ]
    },
    "order_type": {
      "type": "string",
      "enum": [
        "market",
        "limit",
        "stop",
        "stop_limit"
      ]
    },
    "time_in_force": {
      "type": "string",
      "enum": [
        "day",
        "gtc",
        "ioc",
        "fok",
        "opg",
        "cls"
      ]
    },
    "quantity": {
      "type": "number",
      "exclusiveMinimum": 0
    },
    "limit_price": {
      "type": "number"
    },
    "stop_price": {
      "type": "number"
    },
    "risk_tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "submitted_at": {
      "type": "string",
      "format": "date-time"
    },
    "reason": {
      "type": "string"
    }
  }
}

