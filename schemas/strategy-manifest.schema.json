{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://newtradingsystem.local/schemas/strategy-manifest.schema.json",
  "title": "StrategyManifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "strategy_id",
    "version",
    "asset_classes",
    "required_data",
    "required_capabilities",
    "promotion_policy",
    "risk_profile"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "strategy_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9\\-_.]+$"
    },
    "version": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "asset_classes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": [
          "equities",
          "options",
          "futures",
          "crypto"
        ]
      }
    },
    "required_data": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "required_capabilities": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "multi_leg_options": {
          "type": "boolean"
        },
        "short_selling": {
          "type": "boolean"
        },
        "extended_hours": {
          "type": "boolean"
        },
        "continuous_24x7": {
          "type": "boolean"
        },
        "paper_supported": {
          "type": "boolean"
        }
      }
    },
    "promotion_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "stages"
      ],
      "properties": {
        "stages": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "replay",
              "paper_internal",
              "paper_broker",
              "shadow_live",
              "live_canary",
              "live_scaled"
            ]
          }
        },
        "minimum_replay_days": {
          "type": "integer",
          "minimum": 1
        },
        "minimum_paper_trades": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "risk_profile": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "max_gross_notional_usd": {
          "type": "number",
          "minimum": 0
        },
        "max_positions": {
          "type": "integer",
          "minimum": 0
        },
        "max_daily_loss_usd": {
          "type": "number",
          "minimum": 0
        },
        "holding_period": {
          "type": "string",
          "enum": [
            "intraday",
            "swing",
            "position",
            "continuous"
          ]
        }
      }
    }
  }
}

